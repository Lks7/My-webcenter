---
// ServiceCard.astro — 服务卡片组件
// 每个服务展示为一张可点击的卡片，跳转到外链

export interface Props {
  name: string;
  description: string;
  url: string;
  icon?: string;
  category?: string;
  status?: "active" | "maintenance" | "offline";
  featured?: boolean;
  tags?: string[];
  showStatusIndicator?: boolean;
}

const {
  name,
  description,
  url,
  icon = "globe",
  category = "other",
  status = "active",
  featured = false,
  tags = [],
  showStatusIndicator = true,
} = Astro.props;

// 状态样式映射
const statusStyles = {
  active: { dotClass: "dot-active", label: "运行中" },
  maintenance: { dotClass: "dot-maintenance", label: "维护中" },
  offline: { dotClass: "dot-offline", label: "已下线" },
};

// 分类标签映射
const categoryLabels: Record<string, string> = {
  productivity: "生产力",
  tools: "工具",
  social: "社交",
  dev: "开发",
  media: "媒体",
  other: "其他",
};

// SVG 图标映射
const icons: Record<string, string> = {
  globe: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  server: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  code: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  tool: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  music: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  video: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  message: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
};

const iconSvg = icons[icon] ?? icons["globe"];
const currentStatus = statusStyles[status] ?? statusStyles["active"];
const categoryLabel = categoryLabels[category] ?? "其他";
---

<a
  href={status === "offline" ? "javascript:void(0)" : url}
  target={status === "offline" ? "_self" : "_blank"}
  rel="noopener noreferrer"
  class={`service-card ${featured ? "featured" : ""} ${status === "offline" ? "offline" : ""}`}
  aria-label={`访问 ${name} 服务`}
>
  <div class="service-header">
    <div class="service-icon">
      <Fragment set:html={iconSvg} />
    </div>
    <div class="service-meta">
      {
        showStatusIndicator && (
          <span class="status-indicator">
            <span class={`status-dot ${currentStatus.dotClass}`} />
            {currentStatus.label}
          </span>
        )
      }
      <span class="category-tag">{categoryLabel}</span>
    </div>
  </div>

  <div class="service-body">
    <h3 class="service-name">
      {name} {featured && <span class="star-icon">★</span>}
    </h3>
    <p class="service-desc">{description}</p>
  </div>

  {
    tags && tags.length > 0 && (
      <div class="service-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag-item">#{tag}</span>
        ))}
      </div>
    )
  }

  <span class="arrow-indicator">↗</span>
</a>

<style lang="scss">
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius, 12px);
    background-color: var(--color-999);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: all 0.25s ease-in-out;

    &:hover {
      border-color: var(--color-100);
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);

      .arrow-indicator {
        transform: translate(2px, -2px);
        opacity: 0.8;
      }
    }

    &.featured {
      border-width: 1.5px;
      border-color: var(--color-blue);
      &:hover {
        border-color: var(--color-100);
      }
    }

    &.offline {
      opacity: 0.5;
      cursor: not-allowed;
      &:hover {
        transform: none;
        box-shadow: none;
        border-color: var(--border);
      }
    }
  }

  .service-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .service-icon {
    width: 38px;
    height: 38px;
    padding: 8px;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--color-100);
    display: flex;
    align-items: center;
    justify-content: center;

    :global(svg) {
      width: 100%;
      height: 100%;
    }
  }

  .service-meta {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .status-indicator {
    font-size: 11px;
    color: var(--color-300);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;

    &.dot-active {
      background-color: #10b981;
    }
    &.dot-maintenance {
      background-color: #f59e0b;
    }
    &.dot-offline {
      background-color: #ef4444;
    }
  }

  .category-tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--color-300);
    background-color: var(--color-950);
  }

  .service-body {
    .service-name {
      font-size: 18px;
      font-weight: 700;
      color: var(--color-100);
      margin: 0 0 6px 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .star-icon {
      color: var(--color-yellow);
      font-size: 14px;
    }
    .service-desc {
      font-size: 13px;
      line-height: 1.6;
      color: var(--color-300);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .service-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: auto;

    .tag-item {
      font-size: 11px;
      color: var(--color-400);
    }
  }

  .arrow-indicator {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 14px;
    color: var(--color-300);
    opacity: 0;
    transition: all 0.25s ease-in-out;
  }
</style>
