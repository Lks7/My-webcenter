---
import { getCollection } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import siteConfig from "../../site.config";
import ServiceCard from "../../components/ServiceCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { createHash } from "node:crypto";

// 获取所有服务并按 order 排序
const allServices = (await getCollection("services")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

// 按分类分组
const categories = [
  { key: "productivity", label: "生产力", emoji: "⚡" },
  { key: "tools", label: "工具", emoji: "🛠️" },
  { key: "dev", label: "开发", emoji: "💻" },
  { key: "media", label: "媒体", emoji: "🎬" },
  { key: "social", label: "社交", emoji: "💬" },
  { key: "other", label: "其他", emoji: "📦" },
];

// 仅展示有非精选服务的分类（精选已单独展示）
const activeCategories = categories.filter((cat) =>
  allServices.some((s) => s.data.category === cat.key && !s.data.featured)
);

// 置顶的精选服务（featured: true）
const featuredServices = allServices.filter((s) => s.data.featured);

const pageTitle = `${siteConfig.services?.title ?? "服务中心"} | ${siteConfig.title}`;
const pageDesc = siteConfig.services?.description ?? "自部署的工具与服务集合";
const showStatus = siteConfig.services?.showStatusIndicator ?? true;

// 密码保护
const rawPassword = siteConfig.services?.password ?? "";
const passwordHash = rawPassword
  ? createHash("sha256").update(rawPassword).digest("hex")
  : "";
const hasPasswordProtection = passwordHash !== "";
---

<BlogPostLayout title={pageTitle} description={pageDesc}>
  <div class="post">
    <main class="post-wrapper services-page">
      <SectionHeader
        tag="SERVICES"
        description={pageDesc}
      >
        服务中心
      </SectionHeader>

      <section class="border-top" style="padding-top: 2rem;">
        <!-- ── 密码门 ── -->
        {hasPasswordProtection && (
          <div id="password-gate" class="password-gate-container">
            <div class="password-gate-box">
              <div class="gate-icon">🔐</div>
              <h2 class="gate-title">需要密码访问</h2>
              <p class="gate-subtitle">请输入密码以查看服务中心内容</p>
              <div class="gate-input-wrapper" id="gate-input-wrap">
                <input
                  id="password-input"
                  type="password"
                  placeholder="输入访问密码"
                  autocomplete="current-password"
                  maxlength="64"
                  aria-label="服务中心访问密码"
                  class="password-input"
                />
                <button
                  id="password-submit"
                  type="button"
                  class="password-submit-btn"
                >
                  解锁
                </button>
              </div>
              <p id="password-error" role="alert" aria-live="polite" class="password-error"></p>
              <p class="gate-tip">本次访问期间无需重新输入</p>
            </div>
          </div>
        )}

        <!-- ── 服务内容（有密码时初始隐藏） ── -->
        <div id="services-content" style={hasPasswordProtection ? "display:none;" : ""}>
          {allServices.length === 0 ? (
            <div class="empty-state">
              <div class="empty-icon">🚀</div>
              <p class="empty-title">暂无服务</p>
              <p class="empty-desc">
                在 <code>src/content/services/</code> 目录下添加 .md 文件来注册服务。
              </p>
            </div>
          ) : (
            <div class="services-sections-list">
              <!-- 精选服务区块 -->
              {featuredServices.length > 0 && (
                <div class="services-group">
                  <h2 class="services-section-title">
                    <span>⭐</span> 精选服务
                  </h2>
                  <div class="services-grid">
                    {featuredServices.map((service) => (
                      <ServiceCard
                        name={service.data.name}
                        description={service.data.description}
                        url={service.data.url}
                        icon={service.data.icon}
                        category={service.data.category}
                        status={service.data.status}
                        featured={service.data.featured}
                        tags={service.data.tags}
                        showStatusIndicator={showStatus}
                      />
                    ))}
                  </div>
                </div>
              )}

              <!-- 分类服务区块 -->
              {activeCategories.map((cat) => {
                const catServices = allServices.filter(
                  (s) => s.data.category === cat.key && !s.data.featured
                );
                if (catServices.length === 0) return null;
                return (
                  <div class="services-group">
                    <h2 class="services-section-title">
                      <span>{cat.emoji}</span> {cat.label}
                      <span class="services-count">{catServices.length}</span>
                    </h2>
                    <div class="services-grid">
                      {catServices.map((service) => (
                        <ServiceCard
                          name={service.data.name}
                          description={service.data.description}
                          url={service.data.url}
                          icon={service.data.icon}
                          category={service.data.category}
                          status={service.data.status}
                          featured={service.data.featured}
                          tags={service.data.tags}
                          showStatusIndicator={showStatus}
                        />
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          <div class="add-service-tip">
            💡 在 <code>src/content/services/</code> 目录中添加 .md 文件即可注册新服务
          </div>
        </div>
      </section>
    </main>
  </div>

  <!-- 密码验证脚本（在 MainLayout 内部，确保正常执行） -->
  {hasPasswordProtection && (
    <script is:inline define:vars={{ passwordHash, storageKey: "svc_unlocked_v1" }}>
      const STORAGE_KEY = storageKey;
      const CORRECT_HASH = passwordHash;

      async function sha256(str) {
        const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, "0")).join("");
      }

      function unlock() {
        const content = document.getElementById("services-content");
        const gate = document.getElementById("password-gate");
        if (content) { content.style.display = ""; }
        if (gate) { gate.style.display = "none"; }
        sessionStorage.setItem(STORAGE_KEY, "1");
      }

      function init() {
        if (sessionStorage.getItem(STORAGE_KEY) === "1") {
          unlock();
          return;
        }
        const input = document.getElementById("password-input");
        const submitBtn = document.getElementById("password-submit");
        const errorEl = document.getElementById("password-error");
        const wrap = document.getElementById("gate-input-wrap");

        if (!input || !submitBtn) return;

        async function doVerify() {
          const val = input.value.trim();
          if (!val) return;
          submitBtn.textContent = "验证中…";
          submitBtn.disabled = true;
          errorEl.textContent = "";
          try {
            const hash = await sha256(val);
            if (hash === CORRECT_HASH) {
              unlock();
            } else {
              errorEl.textContent = "密码错误，请重试";
              input.value = "";
              input.focus();
              wrap.style.transform = "translateX(0)";
              let count = 0;
              const shakeInterval = setInterval(() => {
                wrap.style.transform = count % 2 === 0 ? "translateX(-5px)" : "translateX(5px)";
                count++;
                if (count > 6) { clearInterval(shakeInterval); wrap.style.transform = "translateX(0)"; }
              }, 70);
            }
          } catch (e) {
            errorEl.textContent = "验证失败，请刷新重试";
          } finally {
            submitBtn.textContent = "解锁";
            submitBtn.disabled = false;
          }
        }

        submitBtn.addEventListener("click", doVerify);
        input.addEventListener("keydown", (e) => { if (e.key === "Enter") doVerify(); });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    </script>
  )}
</BlogPostLayout>

<style lang="scss">
  .services-page {
    display: flex;
    flex-direction: column;
    margin: 0 auto;
  }

  .password-gate-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    width: 100%;
  }

  .password-gate-box {
    width: 100%;
    max-width: 400px;
    border-radius: 12px;
    border: 1px dashed var(--border);
    padding: 48px 32px;
    background-color: var(--color-999);
    text-align: center;
    
    .gate-icon {
      font-size: 48px;
      line-height: 1;
      margin-bottom: 16px;
    }

    .gate-title {
      font-size: 20px;
      font-weight: 700;
      margin: 0 0 8px 0;
      color: var(--color-100);
    }

    .gate-subtitle {
      font-size: 14px;
      color: var(--color-300);
      margin: 0 0 24px 0;
    }

    .gate-tip {
      font-size: 11px;
      color: var(--color-400);
      margin-top: 16px;
      margin-bottom: 0;
    }
  }

  .gate-input-wrapper {
    display: flex;
    border-radius: 8px;
    overflow: hidden;
    border: 1.5px solid var(--border);
    background-color: var(--color-950);
    transition: border-color 0.25s;

    &:focus-within {
      border-color: var(--color-200);
    }
  }

  .password-input {
    flex: 1;
    padding: 10px 14px;
    background: transparent;
    border: none;
    outline: none;
    font-size: 14px;
    color: var(--color-100);
    min-width: 0;
  }

  .password-submit-btn {
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 600;
    background-color: var(--color-900);
    border: none;
    border-left: 1px solid var(--border);
    cursor: pointer;
    color: var(--color-100);
    transition: background-color 0.15s;
    white-space: nowrap;

    &:hover:not(:disabled) {
      background-color: var(--color-800);
    }

    &:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
  }

  .password-error {
    margin-top: 8px;
    margin-bottom: 0;
    font-size: 12px;
    color: #ef4444;
    min-height: 1.2em;
    text-align: left;
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--color-300);

    .empty-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    .empty-title {
      font-size: 18px;
      font-weight: 600;
      margin: 0 0 8px 0;
    }
    .empty-desc {
      font-size: 14px;
      margin: 0;
      code {
        font-family: monospace;
        background-color: var(--color-900);
        padding: 2px 6px;
        border-radius: 4px;
      }
    }
  }

  .services-sections-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .services-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .services-section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 16px 0;
    padding-bottom: 8px;
    border-bottom: 1px dashed var(--border);
    color: var(--color-100);
  }

  .services-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 600;
    background-color: var(--color-900);
    color: var(--color-200);
    margin-left: 8px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .add-service-tip {
    margin-top: 48px;
    padding: 16px;
    font-size: 12px;
    color: var(--color-400);
    text-align: center;
    border-top: 1px dashed var(--border);

    code {
      font-family: monospace;
      padding: 2px 6px;
      background-color: var(--color-900);
      border-radius: 4px;
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
